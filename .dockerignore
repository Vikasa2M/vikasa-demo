.github
.idea
.playwright-mcp
.superpowers
.claude
docs
demo
deploy
scripts
# third_party/vikasa-infra is the topology renderer; it runs on the host
# during `make topology`, never inside this image.
third_party
*.png
*.mp4
*.md
Dockerfile
Makefile
.dockerignore
.gitignore
