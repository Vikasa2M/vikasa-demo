          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-vikasa"
          },
          "editorType": "sql",
          "format": 0,
          "queryType": "timeseries",
          "rawSql": "SELECT toStartOfMinute(ce_time) AS time, mode, count() AS changes FROM vikasa_${dot}.dms_event WHERE event_kind = 'mode-changed' AND $__timeFilter(ce_time) GROUP BY time, mode ORDER BY time",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "partitionByValues",
          "options": {
            "fields": [
              "cabinet_id"
            ],
            "keepFields": false,
            "naming": {
              "asLabels": true
            }
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "mode (.*)",
            "renamePattern": "$1"
          }
        }
      ],
      "title": "DMS mode-change activity by mode ($dot)",
      "type": "timeseries"
    }
