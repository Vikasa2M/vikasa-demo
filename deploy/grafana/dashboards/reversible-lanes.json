          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT toStartOfMinute(p.ce_time) AS time, sum(p.volume) AS vehicles FROM vikasa_mardot.traffic_sensor_lane_interval p INNER JOIN vikasa_mardot.cabinets c ON p.cabinet_id = c.cabinet_id WHERE c.route = 'i75s' AND $__timeFilter(p.ce_time) GROUP BY time ORDER BY time",
