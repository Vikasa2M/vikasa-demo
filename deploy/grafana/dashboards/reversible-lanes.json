      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-vikasa"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT ce_time AS time, CASE WHEN flow_state = 'LANE_FLOW_STATE_IN_TRANSITION' THEN 'Transition' WHEN open_direction = 'TRAVEL_DIRECTION_NORTHBOUND' THEN 'Northbound (inbound)' ELSE 'Southbound (outbound)' END AS direction FROM vikasa_mardot.reversible_lane_state WHERE $__timeFilter(ce_time) ORDER BY ce_time",
          "refId": "A"
        }
      ],
      "title": "Reversal schedule \u2014 open direction over time",
      "type": "state-timeline"
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-vikasa"
      },
      "description": "Each scheduled reversal: when the lanes reopened in a new direction, from which direction, and why (the schedule reason). Keepalive re-reports are excluded \u2014 only real openings.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": []
