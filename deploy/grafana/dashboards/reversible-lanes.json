            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-vikasa"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT CASE WHEN argMax(flow_state, ce_time) = 'LANE_FLOW_STATE_OPEN' THEN 0 WHEN argMax(flow_state, ce_time) = 'LANE_FLOW_STATE_IN_TRANSITION' THEN 1 ELSE 2 END AS flow_state FROM vikasa_mardot.reversible_lane_state",
          "refId": "A"
        }
