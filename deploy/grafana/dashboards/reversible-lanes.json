        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-vikasa"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT ce_time AS time, CASE WHEN previous_direction = 'TRAVEL_DIRECTION_NORTHBOUND' THEN 'Northbound' WHEN previous_direction = 'TRAVEL_DIRECTION_SOUTHBOUND' THEN 'Southbound' ELSE '\u2014' END AS from_direction, CASE WHEN open_direction = 'TRAVEL_DIRECTION_NORTHBOUND' THEN 'Northbound' ELSE 'Southbound' END AS to_direction, initiated_by FROM vikasa_mardot.reversible_lane_state WHERE $__timeFilter(ce_time) AND initiated_by != 'schedule-keepalive' AND flow_state = 'LANE_FLOW_STATE_OPEN' ORDER BY ce_time DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Reversal events",
      "type": "table"
    },
