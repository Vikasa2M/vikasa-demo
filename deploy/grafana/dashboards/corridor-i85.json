                "rotation": { "fixed": 0, "max": 360, "min": -360, "mode": "mod" },
                "size": { "fixed": 8, "max": 15, "min": 2 },
                "symbol": { "fixed": "img/icons/marker/circle.svg", "mode": "fixed" },
                "symbolAlign": { "horizontal": "center", "vertical": "center" },
                "textConfig": { "fontSize": 12, "offsetX": 0, "offsetY": 0, "textAlign": "center", "textBaseline": "middle" }
              }
            },
            "location": { "mode": "auto" },
            "name": "Corridor cabinets",
            "tooltip": true,
            "type": "markers"
          }
        ],
        "tooltip": { "mode": "details" },
        "view": { "allLayers": true, "id": "coords", "lat": 34.3, "lon": -83.2, "zoom": 6 }
      },
      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-vikasa" },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT c.cabinet_id, c.dot, c.lat, c.lon, s.kmh FROM vikasa_federation.cabinets c LEFT JOIN (SELECT cabinet_id, avg(speed_kmh) AS kmh FROM vikasa_federation.traffic_sensor_lane_interval WHERE ce_time > now() - INTERVAL 15 MINUTE GROUP BY cabinet_id) s ON c.cabinet_id = s.cabinet_id WHERE c.corridor = 'i85'",
          "refId": "A"
        }
      ],
      "title": "Corridor map",
      "type": "geomap"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-vikasa" },
      "description": "Corridor incidents currently in 'detected' state (latest state per incident via argMax), across all 3 DOTs. Empty is expected at baseline — populates once an incident scenario is injected on the corridor.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
