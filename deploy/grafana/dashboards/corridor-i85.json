        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-vikasa" },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT dot, cabinet_id, device_id, argMax(mode, ce_time) AS mode, max(ce_time) AS last FROM vikasa_federation.dms_event WHERE event_kind = 'mode-changed' AND ce_time > now() - INTERVAL 6 HOUR GROUP BY dot, cabinet_id, device_id ORDER BY dot, cabinet_id",
          "refId": "A"
        }
      ],
      "title": "DMS advisories on corridor",
      "type": "table"
    },
