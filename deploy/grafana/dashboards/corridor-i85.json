      "id": 3,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-vikasa" },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT dot, cabinet_id, incident_id, argMax(state, ce_time) AS state, max(ce_time) AS last FROM vikasa_federation.perception_incident WHERE ce_time > now() - INTERVAL 6 HOUR GROUP BY dot, cabinet_id, incident_id HAVING state = 'detected'",
          "refId": "A"
        }
      ],
      "title": "Active corridor incidents",
      "type": "table"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-vikasa" },
      "description": "Latest DMS mode per sign on the corridor (argMax over dms_event, event_kind='mode-changed').",
