      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-vikasa" },
          "editorType": "sql",
          "format": 0,
          "queryType": "timeseries",
          "rawSql": "SELECT toStartOfInterval(ce_time, INTERVAL 1 MINUTE) AS time, dot, avg(speed_kmh) AS kmh FROM vikasa_federation.traffic_sensor_lane_interval WHERE $__timeFilter(ce_time) GROUP BY time, dot ORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Corridor speeds by DOT",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-vikasa" },
      "description": "I-85 corridor cabinets (federation dimension, corridor='i85') colored by average lane speed over the last 15 minutes (widened from the nominal 5-minute window to tolerate normal sink/consumer processing lag between ce_time and ingested_at observed on this stack).",
