    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-vikasa"
      },
      "description": "Currently-active controller and DMS faults in the last 24h across all 99 cabinets in all 3 DOTs, grouped by (dot, cabinet, device, fault) \u2014 not just cabinet \u2014 so distinct faults don't collapse into one row. Reads the UNION of vikasa_gdot/ncdot/scdot event tables (not vikasa_federation, which only carries the 3 corridor cabinets) so a fault on ANY of the 99 cabinets appears here, not just corridor ones. Empty is expected at baseline \u2014 populates once a fault scenario is injected.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "id": 3,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-vikasa"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT dot, cabinet_id, device_id, fault_id, argMax(raised, ce_time) AS active, max(ce_time) AS last_seen FROM (SELECT dot, cabinet_id, device_id, fault_id, raised, ce_time FROM vikasa_gdot.controller_fault_event WHERE ce_time > now() - INTERVAL 24 HOUR UNION ALL SELECT dot, cabinet_id, device_id, fault_id, raised, ce_time FROM vikasa_ncdot.controller_fault_event WHERE ce_time > now() - INTERVAL 24 HOUR UNION ALL SELECT dot, cabinet_id, device_id, fault_id, raised, ce_time FROM vikasa_scdot.controller_fault_event WHERE ce_time > now() - INTERVAL 24 HOUR) GROUP BY dot, cabinet_id, device_id, fault_id HAVING active = 1",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-vikasa"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT dot, cabinet_id, device_id, fault_id, argMax(event_kind, ce_time) AS active, max(ce_time) AS last_seen FROM (SELECT dot, cabinet_id, device_id, fault_id, event_kind, ce_time FROM vikasa_gdot.dms_event WHERE ce_time > now() - INTERVAL 24 HOUR AND event_kind IN ('fault-raised', 'fault-cleared') UNION ALL SELECT dot, cabinet_id, device_id, fault_id, event_kind, ce_time FROM vikasa_ncdot.dms_event WHERE ce_time > now() - INTERVAL 24 HOUR AND event_kind IN ('fault-raised', 'fault-cleared') UNION ALL SELECT dot, cabinet_id, device_id, fault_id, event_kind, ce_time FROM vikasa_scdot.dms_event WHERE ce_time > now() - INTERVAL 24 HOUR AND event_kind IN ('fault-raised', 'fault-cleared')) GROUP BY dot, cabinet_id, device_id, fault_id HAVING active = 'fault-raised'",
          "refId": "B"
        }
      ],
      "title": "Active faults (controller + DMS)",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        }
      ],
      "type": "table"
    },
