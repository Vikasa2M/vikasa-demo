      },
      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-vikasa"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT c.dot, avg(c.lat) AS lat, avg(c.lon) AS lon, count() AS cabinets, max(h.freshness_s) AS worst_freshness_s FROM vikasa_federation.cabinets c LEFT JOIN (SELECT dot, cabinet_id, dateDiff('second', max(ingested_at), now64(3)) AS freshness_s FROM (SELECT dot, cabinet_id, ingested_at FROM vikasa_gdot.heartbeats WHERE ce_time > now() - INTERVAL 15 MINUTE UNION ALL SELECT dot, cabinet_id, ingested_at FROM vikasa_ncdot.heartbeats WHERE ce_time > now() - INTERVAL 15 MINUTE UNION ALL SELECT dot, cabinet_id, ingested_at FROM vikasa_scdot.heartbeats WHERE ce_time > now() - INTERVAL 15 MINUTE) GROUP BY dot, cabinet_id) h ON c.dot = h.dot AND c.cabinet_id = h.cabinet_id GROUP BY c.dot",
          "refId": "A"
        }
      ],
      "title": "Fleet map \u2014 the network (3 states \u00d7 33 cabinets)",
      "type": "geomap"
    },
