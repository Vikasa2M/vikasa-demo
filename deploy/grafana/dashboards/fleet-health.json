            "location": {
              "mode": "auto"
            },
            "name": "Cabinets by state",
            "tooltip": true,
            "type": "markers"
          }
        ],
        "tooltip": {
          "mode": "details"
        },
        "view": {
          "allLayers": true,
          "id": "coords",
          "lat": 34.5,
          "lon": -82.6,
          "zoom": 6
