      "type": "text",
      "title": "",
      "transparent": true,
      "options": {
        "mode": "markdown",
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "## The substrate underneath the data \u2014 NATS tiers, JetStream, and ClickHouse.\n\nNine prometheus-nats-exporters watch every leaf, regional, central, and DMZ node, while the sink reports its own event rate, dead letters, and flush latency. This is the plumbing view: message throughput per tier, JetStream API load, ClickHouse storage growth, and how fast the batching sink is committing rows."
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "NATS server liveness via the /varz exporter sidecars \u2014 all 9 tiers (3 DOTs x {regional,central,dmz}).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "down"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "1": {
                  "color": "green",
                  "text": "up"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
