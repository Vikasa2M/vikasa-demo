          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-vikasa"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT database, table, sum(rows) AS rows, formatReadableSize(sum(bytes_on_disk)) AS size, count() AS parts FROM system.parts WHERE active AND database LIKE 'vikasa%' GROUP BY database, table ORDER BY rows DESC",
          "refId": "A"
        }
      ],
      "title": "ClickHouse storage by table",
      "type": "table"
