      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-vikasa"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT c.cabinet_id, c.lat, c.lon, coalesce(p.detections, 0) AS detections, coalesce(i.active_incidents, 0) AS active_incidents FROM vikasa_mardot.cabinets c LEFT JOIN (SELECT cabinet_id, sum(count) AS detections FROM vikasa_mardot.perception_zone_interval WHERE ce_time > now() - INTERVAL 15 MINUTE GROUP BY cabinet_id) p ON c.cabinet_id = p.cabinet_id LEFT JOIN (SELECT cabinet_id, countIf(latest != 'cleared') AS active_incidents FROM (SELECT cabinet_id, incident_id, argMax(state, ce_time) AS latest FROM vikasa_mardot.perception_incident GROUP BY cabinet_id, incident_id) GROUP BY cabinet_id) i ON c.cabinet_id = i.cabinet_id WHERE c.route = 'i85'",
          "refId": "A"
        }
      ],
      "title": "MARDOT I-85 corridor \u2014 perception stations (detections & live incidents)",
      "type": "geomap"
    },
