          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT (SELECT sum(count) FROM vikasa_mardot.perception_zone_interval WHERE $__timeFilter(ce_time) AND cabinet_id IN ($cabinet)) / nullIf((SELECT sum(volume) FROM vikasa_mardot.traffic_sensor_lane_interval WHERE $__timeFilter(ce_time) AND cabinet_id IN ($cabinet)) / nullIf((SELECT uniqExact(device_id) FROM vikasa_mardot.traffic_sensor_lane_interval WHERE $__timeFilter(ce_time) AND cabinet_id IN ($cabinet)), 0), 0) AS ratio",
          "refId": "A"
        }
      ],
      "title": "Fusion agreement ratio",
      "type": "stat"
